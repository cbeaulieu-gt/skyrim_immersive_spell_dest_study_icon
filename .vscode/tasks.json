{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure Debug",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/configure.ps1",
                "-Preset",
                "ninja-vcpkg-debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/build.ps1",
                "-Preset",
                "build-ninja-vcpkg-debug"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Configure Release",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/configure.ps1",
                "-Preset",
                "ninja-vcpkg-release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/build.ps1",
                "-Preset",
                "build-ninja-vcpkg-release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Debug: Configure + Build",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Configure Debug",
                "Build Debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "Release: Configure + Build",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Configure Release",
                "Build Release"
            ],
            "problemMatcher": []
        },
        {
            "label": "Deploy Built DLL (.env default)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/deploy.ps1",
                "-Preset",
                "${input:deployPreset}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Deploy Built DLL + ZIP (.env defaults)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/deploy.ps1",
                "-Preset",
                "${input:deployPreset}",
                "-CreateZip"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Deploy Built DLL (Prompt target)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/deploy.ps1",
                "-Preset",
                "${input:deployPreset}",
                "-TargetDir",
                "${input:deployTargetDir}"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Debug + Deploy (.env default)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Debug",
                "Deploy Built DLL (.env default)"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build Debug + Deploy + ZIP (.env defaults)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Debug",
                "Deploy Built DLL + ZIP (.env defaults)"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build Release + Deploy (.env defaults)",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Build Release",
                "Deploy Release DLL (.env defaults)"
            ],
            "problemMatcher": []
        },
        {
            "label": "Deploy Release DLL (.env defaults)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/deploy.ps1",
                "-Preset",
                "build-ninja-vcpkg-release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Deploy Release DLL + ZIP (.env defaults)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/scripts/deploy.ps1",
                "-Preset",
                "build-ninja-vcpkg-release",
                "-CreateZip"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Release Full: Configure + Build + Deploy + ZIP",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Configure Release",
                "Build Release",
                "Deploy Release DLL + ZIP (.env defaults)"
            ],
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "deployPreset",
            "type": "pickString",
            "description": "Choose the build preset that produced your DLL",
            "default": "build-ninja-vcpkg-release",
            "options": [
                "build-ninja-vcpkg-debug",
                "build-ninja-vcpkg-release"
            ]
        },
        {
            "id": "deployTargetDir",
            "type": "promptString",
            "description": "Destination folder for inventory_injector_known_spells_skse.dll"
        }
    ]
}