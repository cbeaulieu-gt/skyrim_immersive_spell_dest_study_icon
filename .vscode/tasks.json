{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure (Debug)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\run-with-vsdevcmd.ps1",
                "--",
                "cmake",
                "--preset",
                "ninja-vcpkg-debug"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build (Debug)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\run-with-vsdevcmd.ps1",
                "--",
                "cmake",
                "--build",
                "--preset",
                "build-ninja-vcpkg-debug",
                "-v"
            ],
            "dependsOn": "Configure (Debug)",
            "problemMatcher": [
                "$msCompile"
            ],
            "group": "build"
        },
        {
            "label": "Configure (Release)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\run-with-vsdevcmd.ps1",
                "--",
                "cmake",
                "--preset",
                "ninja-vcpkg-release"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build (Release)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\run-with-vsdevcmd.ps1",
                "--",
                "cmake",
                "--build",
                "--preset",
                "build-ninja-vcpkg-release",
                "-v"
            ],
            "dependsOn": "Configure (Release)",
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}